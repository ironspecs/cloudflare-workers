{
	"name": "newsletters",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"config:sync": "node ./scripts/sync-cloudflare-config.mjs",
		"template:check": "node ./scripts/check-public-templates.mjs",
		"template:render": "node ./scripts/render-public-template.mjs",
		"template:sync": "node ./scripts/sync-public-template.mjs",
		"db:check": "node ../node_modules/drizzle-kit/bin.cjs check --config=drizzle.config.ts",
		"db:generate": "node ../node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.ts",
		"deploy": "wrangler deploy",
		"deploy:live": "npm run config:sync && wrangler deploy",
		"deploy:prod": "wrangler deploy -e prod",
		"dev": "wrangler dev",
		"test": "npm run test:unit && npm run test:integration:local",
		"test:coverage": "node ../node_modules/vitest/vitest.mjs run --config=vitest.config.ts --coverage",
		"test:integration:local": "node ./scripts/test-integration-local.mjs",
		"test:unit": "node ../node_modules/vitest/vitest.mjs run --config=vitest.config.ts"
	}
}
